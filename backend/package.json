{
  "name": "medprice-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "restart": "node -e \"const {execSync}=require('child_process');try{execSync('powershell Stop-Process -Id (Get-NetTCPConnection -LocalPort 5000 -State Listen).OwningProcess -Force')}catch(e){}\" && node server.js"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "node-forge": "^1.4.0"
  }
}
